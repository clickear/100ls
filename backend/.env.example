# 100LS Backend Configuration Template
# Copy this file to .env and fill in your actual credentials

# Provider: 'openai' (standard) or 'anthropic' (Claude style)
TRANSLATION_PROVIDER=openai

# Your API Key
TRANSLATION_API_KEY=

# Base URL for the API
# For DeepSeek: https://api.deepseek.com/v1/chat/completions
# For OpenAI: https://api.openai.com/v1/chat/completions
# For Anthropic: https://api.anthropic.com/v1/messages
TRANSLATION_BASE_URL=https://api.openai.com/v1/chat/completions

# Model to use
# Examples: gpt-3.5-turbo, claude-3-haiku-20240307, deepseek-chat
TRANSLATION_MODEL=gpt-3.5-turbo

# Server Port
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://your-domain.com
